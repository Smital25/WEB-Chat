# ---- LLM (any OpenAI-compatible endpoint) ----
# OpenAI:      https://api.openai.com/v1   +  model e.g. gpt-4o-mini
# DeepSeek:    https://api.deepseek.com    +  model deepseek-chat
# Ollama (local, free): http://localhost:11434/v1 + model llama3.1  (LLM_API_KEY can be any string)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---- Web search (Tavily) ----
# Get a free key at https://app.tavily.com  (1000 searches/month free)
TAVILY_API_KEY=your_tavily_api_key_here
